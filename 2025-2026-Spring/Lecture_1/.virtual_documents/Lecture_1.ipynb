import ipywidgets as widgets
from IPython.display import display
import time, threading, os
import datetime


def print_something(sleep_time, something_to_print):
    print("This is print_something function")
    time.sleep(sleep_time)
    print(something_to_print)


# "The main function in the next cell is an example of sequential execution of the code"


label = widgets.Label("🟡 Starting...")
display(label)
if __name__ == "__main__":
    pid = os.getpid()
    tid = threading.get_ident()
    label.value = f"🔵 Running... | PID: {pid} | Thread ID: {tid}"
    start_time = datetime.datetime.now()
    print("This is the main function")
    sleep_time = 5
    something_to_print = "First Call"
    print_something(sleep_time, something_to_print)
    sleep_time = 10
    something_to_print = "Second Call"
    print_something(sleep_time, something_to_print)
    end_time = datetime.datetime.now()
    print(f"It took {end_time - start_time} seconds")
    label.value = f"✅ Done! | PID: {pid} | Thread ID: {tid}"



