from time import sleep, time

def download(file_name):
    print("Downloading file...", file_name)
    sleep(0.5)
    print("Download complete")

files = ['video.mp4','image.png','data.csv']
start = time()
for f in files:
    download(f)
end = time()
print(f"serial time {end - start:.2f} seconds")
print("Bye")





from threading import Thread
from time import sleep, time

threads = []

def download(file_name):
    print("Downloading file...", file_name)
    sleep(0.5)
    print("Download complete")

files = ['video.mp4','image.png','data.csv']

for f in files:
    t = Thread(target=download, args=(f,))
    threads.append(t)

start = time()
for t in threads:
    t.start()

for t in threads:
    t.join()
    
end = time()
print(f"threaded time {end - start:.2f} seconds")
print("Bye")





from threading import Thread
from time import sleep, time

def calculate(n1,n2):
    sum = 0
    for n in range(n1,n2):
        sum+=n*n


num = 50_000_000
start = time()
calculate(0,num)
end = time()
print(f"threaded time {end - start:.2f} seconds")





num = 50_000_000
mid = num // 2

t1 = Thread(target = calculate, args = (0,mid))
t2 = Thread(target = calculate, args = (mid, num))
start = time()
t1.start()
t2.start()
t1.join()
t2.join()
end = time()
print(f"threaded time {end - start:.2f} seconds")



